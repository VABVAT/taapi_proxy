PORT=4010
# Taapi.io JWT — server only; do not expose to the browser.
TAAPI_SECRET=

# Optional: OpenAI for POST /ai/compile-strategy. If empty, the proxy returns a fixed demo strategy so the UI flow still works.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Optional: Supabase prompt logging for POST /ai/compile-strategy.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AI_LOG_TABLE=ai_compile_strategy_prompts
