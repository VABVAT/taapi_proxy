PORT=4010
# Taapi.io JWT — server only; do not expose to the browser.
TAAPI_SECRET=

# Optional: xAI Grok for POST /ai/compile-strategy. If empty, the proxy returns a fixed demo strategy so the UI flow still works.
# GROK_API_KEY=
# GROK_MODEL=grok-2-latest

# Optional: Supabase prompt logging for POST /ai/compile-strategy.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_AI_LOG_TABLE=ai_compile_strategy_prompts
